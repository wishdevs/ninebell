# 더존 옴니솔 대시보드 백엔드 환경변수 예시
# 복사: cp .env.example .env

# PostgreSQL (async). 프로덕션은 운영 DSN 으로 교체.
DATABASE_URL=postgresql+asyncpg://dashboard:dashboard@localhost:5432/dashboard

# 세션 JWT(HS256) 서명키 — 반드시 교체.
AUTH_SECRET=dev-insecure-change-me-please
SESSION_TTL_HOURS=12

# 더존 옴니솔 ERP
ERP_BASE=https://erp.ninebell.co.kr
MAX_CONCURRENT_ERP_LOGINS=3

# LLM 프로바이더: gemini(기본 — GitHub/AWS 배포) | etribe(온프렘 — 사내 Etribe-LLM, 데이터 사외 반출 없음)
LLM_PROVIDER=gemini
# 온프렘 Etribe-LLM(OpenAI 호환) 서버 주소·모델명 — LLM_PROVIDER=etribe 일 때만 사용.
ETRIBE_BASE_URL=http://192.168.50.2:30001
ETRIBE_MODEL=Etribe-LLM

# 최초 로그인 시 super_admin 으로 승격할 옴니솔 userid 목록(쉼표 구분).
SUPER_ADMIN_OMNISOL_IDS=

# 쿠키: 로컬 http=false, 프로덕션 https=true
COOKIE_SECURE=false

# CORS 허용 오리진(쉼표 구분). 프론트 dev 포트 3101.
CORS_ORIGINS=http://localhost:3101

# 개발용: 1 이면 startup 에서 Base.metadata.create_all 로 테이블 생성(Alembic 대체).
DEV_CREATE_ALL=0
