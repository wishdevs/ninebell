# API 런타임 시크릿/설정 — 이 파일을 app.env 로 복사해 서버에 1회 배치(⚠ 리포 커밋 금지).
# DB 는 db 서버(51). asyncpg 드라이버.
DATABASE_URL=postgresql+asyncpg://dashboard:CHANGE_ME@172.20.50.51:5432/dashboard

# 세션 서명 키 — 길고 랜덤하게(예: openssl rand -hex 32).
AUTH_SECRET=CHANGE_ME_LONG_RANDOM

# 로컬 시스템 관리자(admin) 비밀번호 — 반드시 지정(미지정 시 seed 가 '1111' 폴백 + critical 경고).
LOCAL_ADMIN_PASSWORD=CHANGE_ME

# 대화형 카드 에이전트(Gemini). 없으면 해당 기능만 비활성.
GEMINI_API_KEY=

# 쿠키 — 프록시로 same-origin(/api) 이므로 단순. HTTPS면 secure=true, HTTP(:80)면 false.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS — same-origin이라 최소만. 프론트 공개 오리진(들) 쉼표구분.
CORS_ORIGINS=http://172.20.50.52

# 프로덕션은 반드시 false — 스키마는 alembic 마이그레이션이 관리.
DEV_CREATE_ALL=false

# 슈퍼관리자 옴니솔 id(쉼표구분, 선택).
SUPER_ADMIN_OMNISOL_IDS=
