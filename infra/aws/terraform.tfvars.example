# cp terraform.tfvars.example terraform.tfvars  후 값 채우기. tfvars 는 커밋 금지(.gitignore).
region            = "ap-northeast-2"
project           = "ninebell-dashboard"
env               = "test"

# 웹 접근 제한(테스트 권장): 사무실 공인 IP/32
web_ingress_cidrs = ["0.0.0.0/0"]

# 비밀값
gemini_api_key = "AIza...."   # 실제 키

# 이미지 태그(ECR push 태그와 일치)
api_image_tag   = "latest"
front_image_tag = "latest"

# 동시 실행 상한(테스트)
max_concurrent_erp_runs   = 6
max_concurrent_erp_logins = 3

# RDS 버전은 사용 가능 목록에서 확인 후 지정
# postgres_version = "17.4"
